{
  "id": "java-maven-build-fix",
  "language": "java",
  "framework": [
    "maven",
    "junit5"
  ],
  "difficulty": "medium",
  "category": "build_fix",
  "prompt": "修复 mvn clean verify 失败问题，不允许跳过或删除测试。\n\nReal repo context: Maven build metadata is modeled by code/tests that enforce Java target and no skipped tests.",
  "commands": {
    "setup": [],
    "test": [
      "mvn -q test"
    ]
  },
  "constraints": {
    "human": [
      "不允许删除或跳过测试",
      "不允许修改公开 API，除非任务明确要求",
      "必须遵循项目现有代码风格",
      "必须最小化改动范围"
    ],
    "forbid_modify": [
      "hidden_tests/**",
      "src/test/resources/golden/**"
    ],
    "forbid_patterns": [
      "-DskipTests",
      "maven.test.skip",
      "@Disabled",
      "@Ignore",
      "TODO Auto-generated"
    ],
    "require_files_changed": []
  },
  "limits": {
    "timeout_seconds": 900,
    "max_cost_usd": 5.0,
    "max_iterations": 3
  },
  "real_repo": true,
  "repo_notes": "Contains a Java 8 compatible Maven project with production code and JUnit 5 tests."
}
